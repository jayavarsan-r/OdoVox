// Odovox — Prisma schema (Phase 0)
// All money is stored in paise (Int). All timestamps are UTC; format on display in Asia/Kolkata.
// Models holding user data carry a nullable `deletedAt` for soft delete.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Enums
// ===========================================================================

enum MemberRole {
  DOCTOR
  RECEPTIONIST
  ADMIN
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum PatientStatus {
  NEW
  ACTIVE
  IN_CHAIR
  DUE_PAYMENT
  LAB_PENDING
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum VisitStatus {
  SCHEDULED // appointment created, patient hasn't arrived
  CHECKED_IN // receptionist marked arrival; in waiting area
  WAITING // in active queue, assigned to a doctor
  IN_CHAIR // currently being treated
  CHECKOUT // doctor confirmed consultation; awaiting payment/prescription/scheduling
  COMPLETED // fully done, patient left
  CANCELLED // never showed or cancelled before start
  NO_SHOW // didn't arrive within grace period (cron sets this; not in P4)
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  OFFLINE
}

// Audit-grade queue transition log (Phase 4). Separate from AuditLog because queue events
// fire rapid-fire, are read continuously by the activity feed, and have a clinic-scoped
// last-N access pattern. Every queue transition writes one of these AND broadcasts via WS.
enum QueueEventType {
  CHECKED_IN
  CALLED_IN
  RETURNED_TO_QUEUE
  CHECKOUT_STARTED
  COMPLETED
  CANCELLED
  REASSIGNED
  PRIORITY_CHANGED
  DOCTOR_RECORDING
  DOCTOR_RECORDING_DONE
}

enum ConsultationStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

enum JobKind {
  STT
  EXTRACTION_CLINICAL
  EXTRACTION_PRESCRIPTION
  EXTRACTION_INTAKE
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum PlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum ProcedureStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ToothStatus {
  HEALTHY
  CARIES
  FILLED
  EXTRACTED
  CROWN
  RCT
  IMPLANT
  MISSING
  OTHER
}

enum AppointmentStatus {
  SCHEDULED // booked, future
  CHECKED_IN // Phase 4 queue takes over from here
  COMPLETED // converted to a Visit and completed
  CANCELLED // cancelled (by patient, doctor, or system)
  NO_SHOW // didn't show up; cron-set
  RESCHEDULED // soft state: original row marked, new row created
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// Phase 7 lab-case kinds. `type` on LabCase.
enum LabCaseType {
  CROWN
  BRIDGE
  DENTURE_FULL
  DENTURE_PARTIAL
  ALIGNER
  NIGHT_GUARD
  OCCLUSAL_SPLINT
  VENEER
  INLAY_ONLAY
  RPD
  OTHER
}

// Phase 7 lab-case lifecycle, extended in Phase 9.7 for the WhatsApp tracker. The Phase 7 values
// (DELIVERED / RETURNED_FOR_REWORK / COMPLETED) stay valid for existing data; new tracking flows
// through the 9.7 states. See lib/lab/transitions.ts for the reconciled matrix.
enum LabCaseStatus {
  DRAFT // not yet sent
  SENT // sent to vendor
  ACKNOWLEDGED // 9.7: lab confirmed receipt (button or text)
  IN_PROGRESS // lab working
  READY // lab finished the work
  DISPATCHED // 9.7: lab has sent it back; en route
  RECEIVED // 9.7: reached the clinic
  FITTED // 9.7: delivered to the patient (from an Odovox visit, not WhatsApp)
  ISSUE_RAISED // 9.7: remake / query / missing info — resolves back to IN_PROGRESS
  DELIVERED // legacy Phase 7: delivered to patient (try-in or final)
  RETURNED_FOR_REWORK // legacy Phase 7: sent back to vendor for adjustments
  COMPLETED // legacy Phase 7: patient happy, case closed
  CANCELLED // cancelled before completion
}

// Phase 7 inventory stock movements. quantity is signed (see InventoryMovement).
enum MovementKind {
  PURCHASE // +stock; recorded with price
  CONSUMPTION // -stock; tied to a visit
  ADJUSTMENT // ± stock; stock counts / corrections; reason required
  DISPOSAL_EXPIRED // -stock; batch expired/discarded
}

// Phase 8 rewrite. DRAFT while being built during checkout; FINALIZED locks item edits; PARTIAL/PAID
// track payment progress; REFUNDED when fully refunded; CANCELLED voids the bill.
enum BillStatus {
  DRAFT
  FINALIZED
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

// Phase 8. Line-item classification on a Bill.
enum ItemKind {
  PROCEDURE
  LAB_CHARGE
  MATERIAL
  ADJUSTMENT
  OTHER
}

// Phase 8 rewrite. *_MANUAL methods are recorded by the receptionist (system doesn't verify with the
// payer bank). RAZORPAY is the hosted payment-link flow. ADJUSTMENT is a non-money correction.
enum PaymentMethod {
  CASH
  UPI_MANUAL
  CARD_MANUAL
  BANK_TRANSFER
  RAZORPAY
  ADJUSTMENT
}

// Phase 8. PENDING = created but not confirmed (Razorpay link awaiting webhook). SUCCEEDED = money in.
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIAL_REFUND
  CANCELLED
}

// Phase 8. Refund lifecycle. Cash refunds settle SUCCEEDED immediately; Razorpay refunds start
// PENDING and flip on webhook confirmation.
enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum MediaType {
  XRAY
  PHOTO
  DOCUMENT
  LAB_PHOTO
}

// ===========================================================================
// Phase 9 — WhatsApp + Notifications
// ===========================================================================

enum ConsentStatus {
  NOT_ASKED // default — never offered consent
  PENDING // consent request sent, awaiting response (e.g. via opt-in template)
  OPTED_IN // active consent
  OPTED_OUT // explicit refusal or revoked
  EXPIRED // consent older than configured TTL (default 12 months)
}

enum TemplateCategory {
  UTILITY // appointment reminders, receipts (cheapest tier)
  MARKETING // promotional (rarely used by clinics)
  AUTHENTICATION // OTP-like (not used for Odovox)
  SERVICE // post-treatment care, lab updates
}

enum TemplateApprovalStatus {
  PENDING // submitted to Meta, awaiting review
  APPROVED // can be sent
  REJECTED // Meta rejected; needs edits
  PAUSED // clinic paused
  DELETED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  PENDING // queued, not yet sent
  SENT // sent to provider
  DELIVERED // delivered to patient
  READ // patient opened
  FAILED // delivery failed
  RECEIVED // inbound message
  BLOCKED_NO_CONSENT // attempted but blocked by consent check
  BLOCKED_BUDGET // blocked by clinic budget cap
}

enum ConversationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ConversationCategory {
  RESCHEDULE_REQUEST
  COMPLAINT
  GENERAL_QUERY
  PRESCRIPTION_QUESTION
  PAYMENT_QUERY
  OTHER
}

// ===========================================================================
// Auth & Org
// ===========================================================================

model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  name            String
  profilePhotoUrl String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  clinicMembers          ClinicMember[]
  refreshTokens          RefreshToken[]
  auditLogs              AuditLog[]
  createdPatients        Patient[]              @relation("PatientCreatedBy")
  doctorVisits           Visit[]                @relation("VisitDoctor")
  assignedVisits         Visit[]                @relation("VisitAssignedDoctor")
  queueEvents            QueueEvent[]           @relation("QueueEventBy")
  confirmedConsultations Consultation[]         @relation("ConsultationConfirmedBy")
  rejectedConsultations  Consultation[]         @relation("ConsultationRejectedBy")
  consultationEdits      ConsultationEdit[]
  prescriptions          Prescription[]         @relation("PrescriptionDoctor")
  appointments           Appointment[]          @relation("AppointmentDoctor")
  availabilities         DoctorAvailability[]
  labCases               LabCase[]              @relation("LabCaseDoctor")
  createdLabCases        LabCase[]              @relation("LabCaseCreatedBy")
  labVendors             LabVendor[]
  inventoryCategories    InventoryCategory[]
  createdInventoryItems  InventoryItem[]
  inventoryMovements     InventoryMovement[]
  payments               Payment[]
  createdBills           Bill[]                 @relation("BillCreatedBy")
  processedRefunds       Refund[]               @relation("RefundProcessedBy")
  createdPaymentPlans    PaymentPlan[]          @relation("PaymentPlanCreatedBy")
  uploadedMedia          Media[]
  notifications          Notification[]
  prescriptionTemplates  PrescriptionTemplate[] @relation("PrescriptionTemplateCreatedBy")

  @@index([phone])
}

model Clinic {
  id                 String    @id @default(cuid())
  name               String
  joinCode           String    @unique
  addressLine        String
  city               String
  state              String
  pincode            String
  gstNumber          String?
  // Phase 8 billing config. Most small dental clinics are below the GST threshold → exempt by default.
  gstApplicable      Boolean   @default(false)
  gstPercent         Decimal   @default(0) // 18 for dental services when applicable
  // When true, CONSUMPTION inventory movements for a visit auto-add as MATERIAL bill items.
  chargeForMaterials Boolean   @default(false)
  logoUrl            String?
  contactPhone       String
  openingTime        String
  closingTime        String
  lunchStart         String?
  lunchEnd           String?
  weeklyOffDays      Int[]
  chairsCount        Int       @default(1)
  timezone           String    @default("Asia/Kolkata")
  // Grace window (minutes) after startsAt before the NO_SHOW cron marks a SCHEDULED appointment. (Phase 6)
  noShowGraceMinutes Int       @default(30)
  // Phase 9.7 lab WhatsApp tracker: human case codes 'DK-0042' = prefix + per-clinic sequence.
  caseCodePrefix     String? // 2-3 letters; derived from the clinic name on first use
  labCaseSeq         Int       @default(0) // atomic per-clinic counter for case codes
  // Phase 9 WhatsApp config.
  whatsappAccountStatus          String? // 'connected' | 'disconnected' | 'pending'
  whatsappAccountPhoneNumber     String? // clinic's verified WhatsApp business number
  whatsappBudgetPaise            Int? // monthly budget cap (null = unlimited)
  whatsappBudgetWarningThreshold Decimal @default(0.8) // alert at 80% of budget
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  members               ClinicMember[]
  rooms                 Room[]
  patients              Patient[]
  visits                Visit[]
  queueEvents           QueueEvent[]
  appointments          Appointment[]
  doctorAvailabilities  DoctorAvailability[]
  dayOffs               DayOff[]
  appointmentReminders  AppointmentReminder[]
  labVendors            LabVendor[]
  labCases              LabCase[]
  inventoryCategories   InventoryCategory[]
  inventoryItems        InventoryItem[]
  inventoryMovements    InventoryMovement[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  settings              ClinicSetting[]
  media                 Media[]
  jobs                  Job[]
  prescriptionTemplates PrescriptionTemplate[]
  bills                 Bill[]
  refunds               Refund[]
  paymentPlans          PaymentPlan[]
  webhookEvents         WebhookEvent[]
  billReminders         BillReminder[]
  whatsappConsents      PatientWhatsAppConsent[]
  whatsappTemplates     WhatsAppTemplate[]
  whatsappMessages      WhatsAppMessage[]
  patientConversations  PatientConversation[]
  whatsappCostLogs      WhatsAppCostLog[]
  labMessages           LabMessage[]
  labCaseEvents         LabCaseEvent[]

  @@index([joinCode])
}

model ClinicMember {
  id                    String       @id @default(cuid())
  clinicId              String
  userId                String
  role                  MemberRole
  isAdmin               Boolean      @default(false)
  qualification         String?
  // AES-256-GCM ciphertext of the dental-council registration number (PII).
  registrationNumberEnc String?
  specialization        String?
  status                MemberStatus @default(PENDING)
  joinedAt              DateTime     @default(now())
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  deletedAt             DateTime?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@index([clinicId])
  @@index([userId])
}

model OtpRequest {
  id         String    @id @default(cuid())
  phone      String
  otpHash    String
  attempts   Int       @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  ip         String
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([phone])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String?
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json     @default("{}")
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  deviceInfo String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ===========================================================================
// Rooms
// ===========================================================================

model Room {
  id        String     @id @default(cuid())
  clinicId  String
  name      String
  number    String
  status    RoomStatus @default(AVAILABLE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  visits       Visit[]
  appointments Appointment[]

  @@index([clinicId])
}

// ===========================================================================
// Patients (PHI — *Enc fields are AES-256-GCM ciphertext at rest)
// ===========================================================================

model Patient {
  id                String        @id @default(cuid())
  clinicId          String
  patientCode       String
  name              String
  phone             String
  age               Int
  gender            Gender
  bloodGroup        String?
  addressEnc        String? // ENCRYPTED (address is PHI)
  medicalHistoryEnc String? // ENCRYPTED
  allergiesEnc      String? // ENCRYPTED
  medicalFlags      String[]
  chiefComplaint    String? // latest, denormalized for list display
  lastVisitAt       DateTime? // denormalized, maintained in app logic
  outstandingPaise  Int           @default(0) // denormalized for the "Due" badge
  status            PatientStatus @default(NEW)
  createdById       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("PatientCreatedBy", fields: [createdById], references: [id])
  visits         Visit[]
  queueEvents    QueueEvent[]
  treatmentPlans TreatmentPlan[]
  toothRecords   ToothRecord[]
  prescriptions  Prescription[]
  appointments   Appointment[]
  labCases       LabCase[]
  bills          Bill[]
  payments       Payment[]
  media          Media[]
  whatsappConsent      PatientWhatsAppConsent?
  whatsappMessages     WhatsAppMessage[]
  whatsappConversation PatientConversation?

  @@unique([clinicId, patientCode])
  @@index([clinicId, name])
  @@index([clinicId, phone])
  @@index([createdById])
}

// ===========================================================================
// Visits & Consultations
// ===========================================================================

model Visit {
  id                String      @id @default(cuid())
  clinicId          String
  patientId         String
  doctorId          String
  // Which doctor's queue this visit currently sits in (multi-doctor clinics). Kept in sync
  // with doctorId on assign/reassign; the queue read query filters/groups on this.
  assignedDoctorId  String?
  roomId            String?
  status            VisitStatus @default(WAITING)
  tokenNumber       Int
  priority          Int         @default(0) // manual reorder; higher = sooner; 0 = normal FIFO
  // Optimistic-locking counter. Every transition updates WHERE lifecycleVersion = ? then
  // increments it, so two simultaneous call-ins can't both win (see queue routes Part 4.5).
  lifecycleVersion  Int         @default(0)
  scheduledAt       DateTime?
  checkedInAt       DateTime?
  calledInAt        DateTime? // WAITING → IN_CHAIR
  checkoutStartedAt DateTime?
  completedAt       DateTime?
  startedAt         DateTime?
  endedAt           DateTime?
  chiefComplaint    String?
  manualEntry       Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  clinic         Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         User           @relation("VisitDoctor", fields: [doctorId], references: [id])
  assignedDoctor User?          @relation("VisitAssignedDoctor", fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  room           Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  consultation   Consultation?
  sittings       Sitting[]
  prescriptions  Prescription[]
  bills          Bill[]
  media          Media[]
  queueEvents    QueueEvent[]

  // The queue read query: a clinic's active visits, by doctor, priority-then-FIFO.
  @@index([clinicId, status, assignedDoctorId, priority(sort: Desc), checkedInAt(sort: Asc)])
  // Recent activity / current-in-chair lookup.
  @@index([clinicId, status, calledInAt(sort: Desc)])
  @@index([clinicId, status, createdAt])
  @@index([patientId])
  @@index([doctorId])
  @@index([roomId])
}

model QueueEvent {
  id        String         @id @default(cuid())
  clinicId  String
  visitId   String
  patientId String
  type      QueueEventType
  byUserId  String?
  metadata  Json           @default("{}")
  createdAt DateTime       @default(now())

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  visit   Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  byUser  User?   @relation("QueueEventBy", fields: [byUserId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt(sort: Desc)])
  @@index([clinicId, visitId, createdAt(sort: Desc)])
}

model Consultation {
  id                  String             @id @default(cuid())
  visitId             String             @unique
  rawTranscriptEnc    String? // ENCRYPTED — AES-256-GCM ciphertext of the raw transcript (PHI)
  structuredData      Json               @default("{}")
  audioUrl            String?
  audioStorageKey     String? // S3 key (separate from any cached signed URL)
  audioDurationMs     Int?
  languageCode        String? // en-IN | hi-IN | ta-IN
  provider            String? // STT+extraction tag, e.g. "sarvam+gemini"
  sttLatencyMs        Int?
  extractionLatencyMs Int?
  safetyWarnings      String[]           @default([])
  status              ConsultationStatus @default(PENDING_REVIEW)
  confirmedAt         DateTime?
  confirmedById       String?
  rejectedById        String?
  rejectedReason      String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  visit       Visit              @relation(fields: [visitId], references: [id], onDelete: Cascade)
  confirmedBy User?              @relation("ConsultationConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  rejectedBy  User?              @relation("ConsultationRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  edits       ConsultationEdit[]

  @@index([visitId])
  @@index([status])
}

model ConsultationEdit {
  id             String   @id @default(cuid())
  consultationId String
  fieldName      String
  originalValue  String
  editedValue    String
  editedById     String
  createdAt      DateTime @default(now())

  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  editedBy     User         @relation(fields: [editedById], references: [id])

  @@index([consultationId])
  @@index([editedById])
}

// Tracks the voice pipeline's async work (STT + extraction). BullMQ writes these; dashboards
// query them. The (clinicId, status, createdAt) index serves both the worker and clinic views.
model Job {
  id          String    @id @default(cuid())
  clinicId    String
  kind        JobKind
  status      JobStatus @default(QUEUED)
  inputRef    String // the entity this job acts on (e.g. consultationId or mediaId)
  provider    String?
  attempts    Int       @default(0)
  lastError   String?
  durationMs  Int?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status, createdAt])
  @@index([inputRef])
}

// ===========================================================================
// Treatments
// ===========================================================================

model TreatmentPlan {
  id                 String     @id @default(cuid())
  patientId          String
  name               String
  description        String?
  status             PlanStatus @default(DRAFT)
  estimatedCostPaise Int        @default(0)
  createdById        String?
  // The visit where the plan was first created. NULL if created retroactively (Phase 5).
  parentVisitId      String?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedures Procedure[]

  @@index([patientId])
  @@index([status])
}

model Procedure {
  id                String          @id @default(cuid())
  planId            String
  name              String
  toothNumbers      Int[]
  totalSittings     Int             @default(1)
  completedSittings Int             @default(0)
  status            ProcedureStatus @default(PENDING)
  // Phase 8: optional cost dictated by the doctor (voice extraction). Flows to the Bill as the
  // PROCEDURE line's unit price when a bill is auto-populated from a visit.
  estimatedCostPaise Int            @default(0)
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  plan     TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  sittings Sitting[]

  @@index([planId])
}

model Sitting {
  id            String    @id @default(cuid())
  procedureId   String
  visitId       String?
  sittingNumber Int
  // Clinical free text, encrypted at rest (§PHI). Decrypted only in the plan-detail view.
  notesEnc      String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  procedure Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  visit     Visit?    @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@unique([procedureId, sittingNumber])
  @@index([procedureId])
  @@index([visitId])
}

model ToothRecord {
  id              String      @id @default(cuid())
  patientId       String
  toothNumber     Int
  status          ToothStatus @default(HEALTHY)
  history         Json        @default("[]")
  notes           String?
  lastUpdatedById String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, toothNumber])
  @@index([patientId])
}

// ===========================================================================
// Prescriptions
// ===========================================================================

model Prescription {
  id              String    @id @default(cuid())
  visitId         String?
  patientId       String
  doctorId        String
  medicines       Json      @default("[]")
  instructions    String?
  reviewAfterDays Int?
  pdfUrl          String?
  pdfStorageKey   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User    @relation("PrescriptionDoctor", fields: [doctorId], references: [id])

  @@index([visitId])
  @@index([patientId])
  @@index([doctorId])
}

/// Clinic-level reusable prescription bundle (Phase 5). One tap / one voice phrase populates the
/// prescription sheet's medicines. Mutable; existing Prescriptions snapshot medicines at creation
/// (no versioning by reference), so archiving never breaks history.
model PrescriptionTemplate {
  id              String   @id @default(cuid())
  clinicId        String
  createdById     String
  name            String
  description     String?
  isShared        Boolean  @default(true)
  isArchived      Boolean  @default(false)
  medicines       Json     @default("[]") // [{name, dosage, frequency, durationDays, instructions}]
  instructions    String?
  reviewAfterDays Int?
  tags            String[] @default([])
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinic    Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdBy User   @relation("PrescriptionTemplateCreatedBy", fields: [createdById], references: [id])

  @@index([clinicId, isArchived, name])
}

// ===========================================================================
// Appointments
// ===========================================================================

model Appointment {
  id              String            @id @default(cuid())
  clinicId        String
  patientId       String
  doctorId        String
  roomId          String?
  startsAt        DateTime // UTC
  endsAt          DateTime // UTC — computed from durationMinutes
  durationMinutes Int               @default(30)
  status          AppointmentStatus @default(SCHEDULED)
  procedureHint   String?
  notes           String?

  // recurring series support
  seriesId    String? // groups recurring appointments
  seriesIndex Int? // 1-based position within series
  seriesTotal Int? // total in series

  // multi-sitting integration
  treatmentPlanId String? // links to the plan being scheduled
  sittingNumber   Int? // which sitting this is for

  // reschedule audit (denormalized for fast queries)
  originalStartsAt DateTime? // first scheduled time (null if never rescheduled)
  rescheduleCount  Int       @default(0)

  // cancellation
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?

  // no-show
  noShowAt DateTime? // when the cron marked it

  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  clinic    Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient   Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User                  @relation("AppointmentDoctor", fields: [doctorId], references: [id])
  room      Room?                 @relation(fields: [roomId], references: [id], onDelete: SetNull)
  reminders AppointmentReminder[]

  @@index([clinicId, startsAt, doctorId]) // day/week view queries
  @@index([clinicId, status, startsAt]) // status filtering
  @@index([clinicId, seriesId]) // series operations
  @@index([clinicId, patientId, startsAt(sort: Desc)]) // patient's upcoming
}

// Recurring weekly availability template per doctor (Phase 6). A doctor with no rows for a day is
// not available that day. Clinic openingTime/closingTime is the outer envelope; this narrows it.
model DoctorAvailability {
  id            String    @id @default(cuid())
  clinicId      String
  doctorId      String
  dayOfWeek     Int // 0 = Sun, 6 = Sat
  startTime     String // HH:mm in clinic local time, e.g. "09:00"
  endTime       String // HH:mm
  effectiveFrom DateTime? // for future-dated changes (nullable = "always")
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime, effectiveFrom]) // prevent dup entries
  @@index([clinicId, doctorId, dayOfWeek])
}

// One-off blocks: holidays, doctor leave, clinic closure (Phase 6).
model DayOff {
  id          String    @id @default(cuid())
  clinicId    String
  date        DateTime // start of day in clinic timezone
  endDate     DateTime? // for multi-day blocks; null = single day
  scope       String // 'CLINIC' | 'DOCTOR'
  doctorId    String? // required if scope=DOCTOR
  reason      String?
  createdById String
  createdAt   DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, date])
  @@index([clinicId, doctorId, date])
}

// Phase 6 inserts these rows; Phase 9 (WhatsApp/SMS) reads and sends them.
model AppointmentReminder {
  id            String         @id @default(cuid())
  clinicId      String
  appointmentId String
  patientId     String
  scheduledFor  DateTime // when to fire
  channel       String // 'whatsapp' | 'sms' | 'in_app'
  template      String // template key — Phase 9 maps to actual content
  status        ReminderStatus @default(PENDING)
  sentAt        DateTime?
  errorReason   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([clinicId, status, scheduledFor])
  @@index([appointmentId])
}

// ===========================================================================
// Lab
// ===========================================================================

// Phase 7. A lab the clinic works with. Phone + address are PII, encrypted at rest.
model LabVendor {
  id                    String   @id @default(cuid())
  clinicId              String
  name                  String
  contactPhoneEnc       String // ENCRYPTED (AES-256-GCM) — phone is PII
  contactPersonName     String?
  addressEnc            String? // ENCRYPTED — address is PII
  email                 String?
  defaultTurnaroundDays Int      @default(7)
  specialties           String[] // ["crown", "bridge", "denture", "aligner"]
  notes                 String?
  isArchived            Boolean  @default(false)
  // Phase 9.7 WhatsApp tracker. Multiple numbers: owner + technician + pickup boy — technician
  // SIMs change; reception edits this list instantly.
  whatsappPhoneNumbers  String[] @default([])
  preferredLanguage     String   @default("en") // 'en' | 'ta' | 'hi'
  consentLoggedAt       DateTime? // one-time opt-in; null = no outbound sends, ever
  automationPaused      Boolean  @default(false) // per-lab kill switch — manual tracking still works
  createdById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  clinic    Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id])
  cases     LabCase[]
  messages  LabMessage[]

  @@index([clinicId, isArchived, name])
}

// Phase 7. A single lab job (crown, denture, …) tracked through its lifecycle. Lab events are
// recorded in AuditLog (no dedicated event-log model). Photos reuse Media (type=LAB_PHOTO).
model LabCase {
  id         String  @id @default(cuid())
  clinicId   String
  patientId  String
  doctorId   String
  // Nullable since Phase 9.7: a voice-suggested DRAFT is created before reception picks the lab.
  vendorId   String?
  caseNumber String // auto-generated: LC-{first2OfClinicCode}{6 alnum}

  type     LabCaseType
  teeth    Int[] // FDI numbers
  material String? // "PFM", "Zirconia", "Acrylic"
  shade    String? // "A2", "A3.5", "B1"

  description String? // clinical brief

  impressionTakenAt DateTime?
  sentAt            DateTime?
  expectedReturnAt  DateTime? // computed from vendor.defaultTurnaroundDays
  returnedAt        DateTime?
  deliveredAt       DateTime?
  completedAt       DateTime?

  status          LabCaseStatus @default(DRAFT)
  rejectionReason String? // when RETURNED_FOR_REWORK or CANCELLED
  // Phase 9.7: human-readable code 'DK-0042' — present in EVERY WhatsApp message about the case;
  // the threading key (one lab serves many clinics, chat context can't be trusted). Null on
  // pre-9.7 cases until their next transition.
  caseCode        String?
  statusUpdatedAt DateTime      @default(now())
  // 'lab_button' | 'lab_text' | 'llm_parse' | 'reception_manual' | 'reception_voice' | 'timeout_job'
  statusUpdatedBy String        @default("reception_manual")

  costPaise          Int? // clinic pays lab
  patientChargePaise Int? // clinic charges patient
  // Phase 8: set to the Bill id once this case's patient charge has been billed (prevents double-billing).
  billedInBillId     String?

  notesEnc        String? // ENCRYPTED — clinical notes (PHI)
  treatmentPlanId String? // links to Phase 5 plan
  visitId         String? // visit where impression was taken

  // Rework lineage: when a case is sent for rework a new LabCase is cloned, pointing here.
  reworkOfId String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic    Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient   Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User           @relation("LabCaseDoctor", fields: [doctorId], references: [id])
  createdBy User           @relation("LabCaseCreatedBy", fields: [createdById], references: [id])
  vendor    LabVendor?     @relation(fields: [vendorId], references: [id])
  reworkOf  LabCase?       @relation("LabCaseRework", fields: [reworkOfId], references: [id], onDelete: SetNull)
  reworks   LabCase[]      @relation("LabCaseRework")
  photos    Media[]
  events    LabCaseEvent[]
  messages  LabMessage[]

  @@unique([clinicId, caseNumber])
  @@unique([clinicId, caseCode])
  @@index([clinicId, status, expectedReturnAt])
  @@index([clinicId, patientId, createdAt(sort: Desc)])
  @@index([clinicId, vendorId, status])
  @@index([doctorId])
}

// Phase 9.7 — one WhatsApp message between the clinic and a lab. Mirrors WhatsAppMessage but kept
// separate: different lifecycle (parse tiers, resolution), different query patterns, and lab
// traffic must never pollute patient conversation queries.
model LabMessage {
  id              String           @id @default(cuid())
  clinicId        String
  labVendorId     String?
  labCaseId       String?
  direction       MessageDirection // OUTBOUND | INBOUND
  waMessageId     String           @unique // BSP message id — the webhook idempotency key
  body            String?
  mediaPaths      String[] // storage keys of inbound media awaiting attachment
  parseTier       String? // 'button' | 'case_code' | 'llm' | 'manual'
  parseConfidence Decimal?
  resolved        Boolean          @default(false)
  buttonPayload   Json? // structured quick-reply data from the BSP
  fromPhone       String? // inbound sender in E.164 (kept for unknown-sender review)
  templateKey     String? // outbound: which template fired (T1/T2/T3/T4/T-consent)
  costPaise       Int              @default(0)
  createdAt       DateTime         @default(now())

  clinic  Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  vendor  LabVendor? @relation(fields: [labVendorId], references: [id], onDelete: SetNull)
  labCase LabCase?   @relation(fields: [labCaseId], references: [id], onDelete: SetNull)

  @@index([clinicId, labVendorId, createdAt(sort: Desc)])
  @@index([clinicId, resolved, createdAt])
}

// Phase 9.7 — immutable status history per lab case. Separate from AuditLog because this is
// user-facing timeline data (source links, undo affordances), not a compliance trail.
model LabCaseEvent {
  id                 String   @id @default(cuid())
  clinicId           String
  labCaseId          String
  fromStatus         String?
  toStatus           String
  trigger            String // same vocabulary as LabCase.statusUpdatedBy
  sourceLabMessageId String? // links the timeline entry to the WhatsApp message that caused it
  note               String?
  byUserId           String? // set for reception_manual / reception_voice
  undoneAt           DateTime? // set when a reception undo reverses this (LLM) transition
  createdAt          DateTime @default(now())

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  labCase LabCase @relation(fields: [labCaseId], references: [id], onDelete: Cascade)

  @@index([labCaseId, createdAt(sort: Desc)])
  @@index([clinicId, createdAt])
}

// ===========================================================================
// Inventory
// ===========================================================================

// Phase 7. Clinic-defined item grouping (Consumables, Anaesthetics, …). A table, not an enum,
// so clinics can add their own. Archived categories keep their items (items retain categoryId).
model InventoryCategory {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  iconName    String? // lucide icon name (e.g. "syringe", "box", "pill")
  sortOrder   Int      @default(0)
  isArchived  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  clinic    Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdBy User            @relation(fields: [createdById], references: [id])
  items     InventoryItem[]

  @@unique([clinicId, name])
}

// Phase 7. A stocked item. STOCK CONVENTION: currentStock/reorderLevel are Int. For fractional
// units (e.g. 3.5 ml carpule) store the value × 1000 (3500); movement quantities use the same
// scale. Whole-unit items (gloves, needles) store the count directly. Stock changes ONLY via
// InventoryMovement — never edit currentStock directly.
model InventoryItem {
  id         String @id @default(cuid())
  clinicId   String
  categoryId String

  name          String
  sku           String?
  unitOfMeasure String // "piece", "box", "ml", "carpule"

  currentStock Int @default(0) // see STOCK CONVENTION above
  reorderLevel Int @default(0) // low-stock alert threshold

  vendorName             String? // free text — inventory vendor ≠ LabVendor
  lastPurchasePricePaise Int?
  lastPurchaseDate       DateTime?

  batchNumber String?
  expiryDate  DateTime? // null for non-expiring items (instruments)

  notes       String?
  isArchived  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic    Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  category  InventoryCategory   @relation(fields: [categoryId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  movements InventoryMovement[]

  @@index([clinicId, isArchived, categoryId, name])
  @@index([clinicId, currentStock, reorderLevel]) // low-stock query
  @@index([clinicId, expiryDate]) // expiry alert query
}

// Phase 7. The only way item stock changes. quantity is signed: +ve PURCHASE/ADJUSTMENT-up,
// -ve CONSUMPTION/DISPOSAL/ADJUSTMENT-down. Insert + item.currentStock update are one transaction.
model InventoryMovement {
  id       String       @id @default(cuid())
  clinicId String
  itemId   String
  kind     MovementKind
  quantity Int // signed (see STOCK CONVENTION on InventoryItem)

  pricePerUnitPaise Int? // for PURCHASE; null otherwise
  totalPricePaise   Int? // denormalized for fast reports

  visitId       String? // CONSUMPTION linked to a visit
  procedureName String? // free-text context

  batchNumber String? // overrides item batch on PURCHASE
  expiryDate  DateTime?

  reason    String? // required for ADJUSTMENT / DISPOSAL_EXPIRED
  byUserId  String
  createdAt DateTime @default(now())

  clinic Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  byUser User          @relation(fields: [byUserId], references: [id])

  @@index([clinicId, itemId, createdAt(sort: Desc)])
  @@index([clinicId, kind, createdAt(sort: Desc)])
}

// ===========================================================================
// Billing
// ===========================================================================

// Phase 8 rewrite. An itemized invoice. All money in paise (Int). Totals are computed server-side
// on finalize/payment — never trusted from the client. Patient name/phone are snapshotted at finalize
// so a later patient rename doesn't rewrite history.
model Bill {
  id        String  @id @default(cuid())
  clinicId  String
  patientId String
  visitId   String?

  billNumber String // auto: BL-{first2OfJoinCode}{6 alnum}; allocated at create/finalize

  // Identity snapshots (frozen at finalize)
  patientNameSnapshot  String  @default("")
  patientPhoneSnapshot String  @default("")
  doctorIdSnapshot     String?

  // Totals — all paise, all Int
  subtotalPaise  Int     @default(0)
  discountPaise  Int     @default(0)
  discountReason String?

  gstApplicable Boolean @default(false) // copied from clinic at bill creation
  gstPercent    Decimal @default(0) // e.g. 18 for dental (9% CGST + 9% SGST)
  gstPaise      Int     @default(0)

  totalPaise    Int @default(0) // subtotal - discount + gst
  paidPaise     Int @default(0) // sum of non-refunded succeeded payments
  refundedPaise Int @default(0)
  balancePaise  Int @default(0) // total - paid + refunded

  status BillStatus @default(DRAFT)
  notes  String?

  finalizedAt     DateTime?
  paidInFullAt    DateTime?
  cancelledAt     DateTime?
  cancelledReason String?

  // Lazily-generated invoice PDF (Phase 4.5 pattern)
  pdfUrl        String?
  pdfStorageKey String?

  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit        Visit?        @relation(fields: [visitId], references: [id], onDelete: SetNull)
  createdBy    User          @relation("BillCreatedBy", fields: [createdById], references: [id])
  items        BillItem[]
  payments     Payment[]
  refunds      Refund[]
  paymentPlans PaymentPlan[]

  @@unique([clinicId, billNumber])
  @@index([clinicId, status, createdAt(sort: Desc)])
  @@index([clinicId, patientId, createdAt(sort: Desc)])
  @@index([clinicId, balancePaise]) // outstanding reports
  @@index([visitId])
}

// Phase 8. A single line on a Bill. Editable only while the Bill is DRAFT.
model BillItem {
  id       String @id @default(cuid())
  billId   String
  clinicId String

  kind        ItemKind
  description String

  sourceType String? // 'procedure' | 'lab_case' | 'inventory' | 'manual'
  sourceId   String? // FK-ish to Procedure / LabCase / InventoryMovement / etc.

  quantity       Int @default(1)
  unitPricePaise Int
  discountPaise  Int @default(0)
  subtotalPaise  Int // (unit * qty) - discount

  notes     String?
  createdAt DateTime @default(now())

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([clinicId, sourceType, sourceId])
}

// Phase 8 rewrite. A payment against a Bill. Idempotent on (clinicId, idempotencyKey) — retrying a
// flaky network call with the same key returns the existing row instead of double-charging.
model Payment {
  id        String @id @default(cuid())
  clinicId  String
  billId    String
  patientId String

  paymentNumber String // auto: PAY-{first2OfJoinCode}{6 alnum}

  amountPaise Int
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)

  // Method-specific (only the relevant ones populated)
  upiId       String?
  upiTxnRef   String?
  cardLast4   String?
  cardNetwork String?
  bankTxnRef  String?

  // Razorpay-specific
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpayLinkId    String?
  razorpaySignature String?
  razorpayFee       Int     @default(0)

  idempotencyKey String

  receivedById String
  receivedAt   DateTime?

  notes String?

  refundedAmountPaise Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bill       Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  receivedBy User     @relation(fields: [receivedById], references: [id])
  refunds    Refund[]

  @@unique([clinicId, paymentNumber])
  @@unique([clinicId, idempotencyKey]) // CRITICAL — prevents double-charge on retry
  @@index([clinicId, status, createdAt(sort: Desc)])
  @@index([billId])
  @@index([razorpayPaymentId])
  @@index([razorpayLinkId])
}

// Phase 8. A refund against a Payment. Cash refunds settle immediately; Razorpay refunds flip from
// PENDING on webhook confirmation.
model Refund {
  id        String @id @default(cuid())
  clinicId  String
  paymentId String
  billId    String

  refundNumber String // auto: RF-{first2OfJoinCode}{6 alnum}

  amountPaise Int
  reason      String
  method      PaymentMethod

  razorpayRefundId String?
  razorpayStatus   String?

  status RefundStatus @default(PENDING)

  processedById String
  processedAt   DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  processedBy User    @relation("RefundProcessedBy", fields: [processedById], references: [id])

  @@unique([clinicId, refundNumber])
  @@index([clinicId, paymentId])
  @@index([clinicId, createdAt(sort: Desc)])
}

// Phase 8. Installment schedule for a Bill. Phase 8 only tracks the schedule (no auto-collection).
// Each installment's status is computed from payments linked to the bill.
model PaymentPlan {
  id           String   @id @default(cuid())
  clinicId     String
  billId       String
  totalPaise   Int
  installments Json     @default("[]") // [{ amountPaise, dueDate, paymentId?, status }]
  notes        String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic    Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  bill      Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  createdBy User   @relation("PaymentPlanCreatedBy", fields: [createdById], references: [id])

  @@index([clinicId, billId])
}

// Phase 8. Inbound payment-gateway webhook ledger. Dedup on (source, eventId) so replays are no-ops.
model WebhookEvent {
  id          String    @id @default(cuid())
  clinicId    String?
  source      String // 'razorpay'
  eventId     String // the gateway's event id
  eventType   String
  payload     Json
  signature   String
  status      String // 'received' | 'processed' | 'duplicate' | 'failed'
  errorDetail String?
  processedAt DateTime?
  receivedAt  DateTime  @default(now())

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@unique([source, eventId])
  @@index([clinicId, receivedAt(sort: Desc)])
}

// Phase 8 (Phase 9 sends these). Billing-event reminders: "send bill via WhatsApp", payment receipt,
// outstanding-balance nudge. Mirrors AppointmentReminder; `type` distinguishes the billing event.
model BillReminder {
  id           String         @id @default(cuid())
  clinicId     String
  billId       String
  patientId    String
  type         String // 'BILL_FINALIZED' | 'PAYMENT_RECEIVED' | 'OUTSTANDING'
  scheduledFor DateTime
  channel      String // 'whatsapp' | 'sms' | 'in_app'
  template     String
  status       ReminderStatus @default(PENDING)
  sentAt       DateTime?
  errorReason  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status, scheduledFor])
  @@index([billId])
}

// ===========================================================================
// Media
// ===========================================================================

model Media {
  id           String    @id @default(cuid())
  clinicId     String
  patientId    String
  visitId      String?
  labCaseId    String? // Phase 7 — set for type=LAB_PHOTO
  type         MediaType
  source       String    @default("clinic_upload") // 'clinic_upload' | 'lab_whatsapp' (Phase 9.7)
  storageKey   String // opaque S3/MinIO object key
  url          String? // cached signed URL — regenerated on read
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  thumbnailKey String?
  notesEnc     String? // ENCRYPTED
  uploadedById String
  uploadedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit      Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)
  labCase    LabCase? @relation(fields: [labCaseId], references: [id], onDelete: SetNull)
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@index([clinicId, patientId, uploadedAt])
  @@index([patientId])
  @@index([visitId])
  @@index([labCaseId])
  @@index([uploadedById])
}

// ===========================================================================
// Notifications
// ===========================================================================

model Notification {
  id        String    @id @default(cuid())
  userId    String
  clinicId  String?
  type      String
  title     String
  body      String
  payload   Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clinicId])
  @@index([readAt])
}

// ===========================================================================
// Settings
// ===========================================================================

model ClinicSetting {
  id        String   @id @default(cuid())
  clinicId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, key])
  @@index([clinicId])
}

// ===========================================================================
// Phase 9 — WhatsApp models
// ===========================================================================

// Explicit, auditable per-patient WhatsApp consent (DPDP-compliant). No message is ever sent
// unless status = OPTED_IN and not expired (see checkConsent). Every state change records who + how.
model PatientWhatsAppConsent {
  id        String @id @default(cuid())
  clinicId  String
  patientId String @unique

  status ConsentStatus @default(NOT_ASKED)

  optedInAt       DateTime?
  optedInByUserId String? // who marked consent (receptionist, doctor)
  optedInMethod   String? // 'verbal' | 'written' | 'signup_form' | 'patient_initiated'

  optedOutAt     DateTime?
  optedOutReason String?

  lastReconfirmedAt DateTime? // for periodic re-consent (DPDP best practice)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([clinicId, patientId])
  @@index([clinicId, status])
}

// A Meta-approved template the clinic can send. Curated set (no self-service). Tracks approval + config.
model WhatsAppTemplate {
  id       String @id @default(cuid())
  clinicId String

  templateKey  String // internal identifier: 'appointment_reminder_24h'
  templateName String // Meta's template name in AiSensy
  language     String @default("en") // 'en' | 'hi'

  category       TemplateCategory
  approvalStatus TemplateApprovalStatus @default(PENDING)

  body      String // template body for preview/audit
  variables String[] // ordered variable names: ['patient_name', 'appt_time']

  isEnabled Boolean @default(true) // clinic-level enable/disable

  estimatedCostPaise Int @default(35) // ~₹0.35 per conversation in India

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic   Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]

  @@unique([clinicId, templateKey])
  @@index([clinicId, isEnabled])
}

// Every outbound + inbound message. The @@unique on idempotencyKey is what makes send retries safe.
model WhatsAppMessage {
  id        String @id @default(cuid())
  clinicId  String
  patientId String?

  direction MessageDirection

  // Outbound-specific
  templateId        String?
  templateVariables Json?
  body              String
  attachments       Json? // [{ type: 'pdf', url, name }]

  // Provider correlation
  providerMessageId String?
  providerStatus    String? // 'queued' | 'sent' | 'delivered' | 'read' | 'failed'
  costPaise         Int     @default(0)

  idempotencyKey String?

  // Trigger source
  triggerType       String?
  triggerEntityType String?
  triggerEntityId   String?

  // Inbound-specific
  inboundFromPhone String?
  inboundType      String? // 'text' | 'button_reply' | 'list_reply' | 'image' | 'document'
  inboundButtonId  String?

  status        MessageStatus @default(PENDING)
  failureReason String?

  conversationId String?

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?

  createdById String? // null for system-triggered sends
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic       Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient?             @relation(fields: [patientId], references: [id], onDelete: SetNull)
  template     WhatsAppTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  conversation PatientConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@unique([clinicId, idempotencyKey])
  @@index([clinicId, patientId, createdAt(sort: Desc)])
  @@index([clinicId, status, createdAt(sort: Desc)])
  @@index([clinicId, conversationId, createdAt(sort: Desc)])
  @@index([providerMessageId])
}

// One conversation thread per patient — the unit of the receptionist inbox. Tracks the WhatsApp
// 24-hour session window (free-text replies only allowed while open).
model PatientConversation {
  id        String @id @default(cuid())
  clinicId  String
  patientId String @unique

  status ConversationStatus @default(OPEN)

  category ConversationCategory?

  // 24-hour window awareness
  lastInboundAt   DateTime?
  windowExpiresAt DateTime? // lastInboundAt + 24h

  lastMessageAt      DateTime?
  lastMessagePreview String?

  unreadCount Int @default(0)

  assignedToUserId String?

  resolvedAt       DateTime?
  resolvedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic   Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]

  @@unique([clinicId, patientId])
  @@index([clinicId, status, lastMessageAt(sort: Desc)])
}

// Monthly per-clinic cost rollup, recomputed daily by cron from WhatsAppMessage rows.
model WhatsAppCostLog {
  id       String @id @default(cuid())
  clinicId String
  month    Int // 1..12
  year     Int

  conversationsCount Int @default(0)
  utilityCount       Int @default(0)
  serviceCount       Int @default(0)
  marketingCount     Int @default(0)

  totalCostPaise Int @default(0)

  computedAt DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, year, month])
}
