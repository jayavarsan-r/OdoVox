    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@odovox/db": "workspace:*",
    "@odovox/types": "workspace:*",
    "@sentry/node": "^9.27.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.53.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
