# App
NODE_ENV=development
LOG_LEVEL=info

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
PORT=4000
CORS_ORIGINS=http://localhost:3000

# Database & Redis
# Standard ports. If you already run a native Postgres/Redis on 5432/6379 (common on macOS
# via Homebrew), set POSTGRES_PORT/REDIS_PORT to free ports (e.g. 5433/6380) so the Odovox
# docker containers don't collide, and point the URLs below at those ports.
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_URL=postgresql://odovox:odovox@localhost:5432/odovox?schema=public
REDIS_URL=redis://localhost:6379

# JWT — RS256 PEM keys, base64-encoded (see README for openssl one-liners)
JWT_PRIVATE_KEY=<base64-encoded-pkcs8-private-pem>
JWT_PUBLIC_KEY=<base64-encoded-spki-public-pem>
JWT_ISSUER=odovox
JWT_AUDIENCE=odovox-web

# Cookies
COOKIE_SECRET=<32-byte-random-string>

# PHI encryption — 32 bytes, base64-encoded
PHI_ENCRYPTION_KEY=<base64-32-byte-key>
PHI_KEY_VERSION=1

# OTP delivery
OTP_PROVIDER=mock              # 'mock' (logs code to console) | 'msg91' (real SMS)
MSG91_AUTH_KEY=<your-key>      # required when OTP_PROVIDER=msg91
MSG91_TEMPLATE_ID=<your-dlt-template-id>  # required when OTP_PROVIDER=msg91
MSG91_SENDER_ID=ODOVOX

# STT (speech-to-text) — see docs/voice-pipeline.md for the mock-vs-real policy
STT_PROVIDER=mock              # 'mock' (deterministic canned transcript) | 'sarvam' (real API)
SARVAM_API_KEY=<your-key>      # required when STT_PROVIDER=sarvam
SARVAM_MODEL=saarika:v2.5

# AI extraction
AI_PROVIDER=mock               # 'mock' (keyword pattern-match) | 'gemini' (real API)
GEMINI_API_KEY=<your-key>      # required when AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# Payments
PAYMENT_PROVIDER=mock              # 'mock' (deterministic, no network) | 'razorpay' (real API)
RAZORPAY_KEY_ID=<your-key>         # required when PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_SECRET=<your-secret>
RAZORPAY_WEBHOOK_SECRET=<your-webhook-secret>
RAZORPAY_MODE=test                 # 'test' | 'live' — flags receipts; key swap handles the rest
PAYMENT_MOCK_FAILURE_RATE=0        # 0..1 — fraction of mock captures that simulate failure (chaos)

# Storage — S3-compatible (MinIO in dev; S3 / R2 / Wasabi in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=odovox
S3_SECRET_KEY=odovox-dev-password
S3_BUCKET=odovox-media
S3_FORCE_PATH_STYLE=true
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Sentry (optional — leave blank to disable)
SENTRY_DSN=

# WhatsApp (Phase 9 patient messaging + Phase 9.7 lab tracker — one provider for both)
WHATSAPP_PROVIDER=mock             # 'mock' (deterministic, no network) | 'aisensy' (real BSP)
AISENSY_API_KEY=<your-key>         # required when WHATSAPP_PROVIDER=aisensy
AISENSY_WEBHOOK_SECRET=<your-webhook-secret>
AISENSY_BASE_URL=https://backend.aisensy.com
MOCK_WHATSAPP_FAILURE_RATE=0       # 0..1 — fraction of mock sends that simulate failure (chaos)
