# App
NODE_ENV=development
LOG_LEVEL=info

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
PORT=4000
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://odovox:odovox@localhost:5432/odovox?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT — RS256 PEM keys, base64-encoded (see README for openssl one-liners)
JWT_PRIVATE_KEY=<base64-encoded-pkcs8-private-pem>
JWT_PUBLIC_KEY=<base64-encoded-spki-public-pem>
JWT_ISSUER=odovox
JWT_AUDIENCE=odovox-web

# Cookies
COOKIE_SECRET=<32-byte-random-string>

# PHI encryption — 32 bytes, base64-encoded
PHI_ENCRYPTION_KEY=<base64-32-byte-key>
PHI_KEY_VERSION=1

# OTP delivery
OTP_PROVIDER=mock              # 'mock' (logs code to console) | 'msg91' (real SMS)
MSG91_AUTH_KEY=<your-key>      # required when OTP_PROVIDER=msg91
MSG91_TEMPLATE_ID=<your-dlt-template-id>  # required when OTP_PROVIDER=msg91
MSG91_SENDER_ID=ODOVOX

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
